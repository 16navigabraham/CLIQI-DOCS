{
  "buildCommand": "next build && pagefind --site .next/server/app --output-path public/_pagefind",
  "headers": [
    {
      "source": "/_pagefind/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
